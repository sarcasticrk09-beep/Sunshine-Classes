# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Mailer Settings (For sending real email receipts and alerts)
# For Brevo (Sendinblue):
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT=587
# SMTP_FROM must be a verified sender in your Brevo account dashboard!
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Sunshine Classes <your-verified-brevo-email@domain.com>"

# Cloudinary Integration Keys for Production Media Handling
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Google Analytics & GTM Configuration
VITE_GA_MEASUREMENT_ID=
VITE_GTM_ID=
VITE_SITE_URL=

# Server-side Cloudinary Keys (ONLY stored on Railway/server env, never exposed to frontend)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Service Account Credentials (JSON string for Backend / Railway)
# Download service account key JSON file from Firebase Console -> Project Settings -> Service accounts
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"sunshine-classes-production","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@sunshine-classes-production.iam.gserviceaccount.com"}'

# Optional Firestore Named Database ID (Leave blank or (default) if using standard default database)
FIREBASE_DATABASE_ID="(default)"

# Optional Frontend Firebase Overrides (If overriding build defaults)
VITE_FIREBASE_PROJECT_ID="sunshine-classes-production"
VITE_FIREBASE_APP_ID="1:996750335749:web:fead7d5fdea73b78cfe16c"
VITE_FIREBASE_API_KEY="AIzaSyCPZA9lz7YSQ4kkqD6JxDyyxAaQrO3kqyo"
VITE_FIREBASE_AUTH_DOMAIN="sunshine-classes-production.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="sunshine-classes-production.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="996750335749"

# Meta WhatsApp Cloud API Integration Settings
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""
META_BUSINESS_ACCOUNT_ID=""
META_VERIFY_TOKEN="sunshine_whatsapp_verify_token_2026"
META_APP_SECRET=""



