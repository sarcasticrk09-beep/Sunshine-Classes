{
  "entities": {
    "User": {
      "title": "User",
      "description": "User authentication credentials and account state.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "passwordHash": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "RECEPTIONIST", "TEACHER", "STUDENT"] },
        "status": { "type": "string", "enum": ["ACTIVE", "DISABLED", "LOCKED"] },
        "lastLogin": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["username", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student profile metadata (no embedded payment/attendance histories).",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "rollNumber": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "fatherName": { "type": "string" },
        "motherName": { "type": "string" },
        "phone": { "type": "string" },
        "alternatePhone": { "type": "string" },
        "address": { "type": "string" },
        "classId": { "type": "string" },
        "teacherId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "joiningDate": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" },
        "updatedAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["rollNumber", "name", "fatherName", "phone", "classId"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Teacher profile and class assignment.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "assignedClasses": { "type": "array" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "phone"]
    },
    "Class": {
      "title": "Class",
      "description": "Class standard learning cohorts (Class 1 to Class 10+).",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "className": { "type": "string" },
        "displayOrder": { "type": "number" },
        "monthlyFee": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["className", "monthlyFee"]
    },
    "Admission": {
      "title": "Admission",
      "description": "Historical enrollment records.",
      "type": "object",
      "properties": {
        "admissionId": { "type": "string" },
        "studentId": { "type": "string" },
        "admissionDate": { "type": "string" },
        "session": { "type": "string" },
        "discount": { "type": "number" },
        "remarks": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["studentId", "admissionDate"]
    },
    "Fee": {
      "title": "Fee",
      "description": "Monthly or annual fee obligations per student.",
      "type": "object",
      "properties": {
        "feeId": { "type": "string" },
        "studentId": { "type": "string" },
        "billingPeriod": { "type": "string", "description": "YYYY-MM format e.g. 2026-07" },
        "month": { "type": "number", "description": "Numeric month 1-12" },
        "year": { "type": "number", "description": "Numeric year e.g. 2026" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "PAID", "PARTIAL"] },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" },
        "updatedAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["studentId", "billingPeriod", "amount", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Individual transaction payments.",
      "type": "object",
      "properties": {
        "paymentId": { "type": "string" },
        "studentId": { "type": "string" },
        "feeId": { "type": "string" },
        "amountPaid": { "type": "number" },
        "paymentMode": { "type": "string", "enum": ["CASH", "UPI", "ONLINE", "CARD", "NET_BANKING"] },
        "transactionId": { "type": "string" },
        "receiptNumber": { "type": "string" },
        "receivedBy": { "type": "string" },
        "paymentDate": { "type": "string" },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["studentId", "feeId", "amountPaid", "paymentMode"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance logs.",
      "type": "object",
      "properties": {
        "attendanceId": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["PRESENT", "ABSENT", "LATE", "LEAVE"] },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["studentId", "date", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Logged messages across channels.",
      "type": "object",
      "properties": {
        "notificationId": { "type": "string" },
        "type": { "type": "string", "enum": ["WhatsApp", "Email", "SMS", "App"] },
        "recipient": { "type": "string" },
        "status": { "type": "string", "enum": ["SENT", "FAILED", "PENDING"] },
        "sentBy": { "type": "string" },
        "sentAt": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["type", "recipient", "status"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "System operational audit history.",
      "type": "object",
      "properties": {
        "logId": { "type": "string" },
        "action": { "type": "string" },
        "performedBy": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["action", "performedBy"]
    },
    "StudyMaterial": {
      "title": "StudyMaterial",
      "description": "Public and private study materials, notes, worksheets, PYQs, and educational resources.",
      "type": "object",
      "properties": {
        "materialId": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "chapter": { "type": "string" },
        "materialType": { "type": "string", "enum": ["PDF", "NOTES", "WORKSHEET", "QUESTION_BANK", "PYQ", "SAMPLE_PAPER", "FORMULA_SHEET", "NCERT_SOLUTION", "VIDEO_LINK", "EXTERNAL_LINK", "BLOG"] },
        "fileUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "externalUrl": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED", "ARCHIVED"] },
        "downloadCount": { "type": "number" },
        "viewCount": { "type": "number" },
        "tags": { "type": "array" },
        "seoTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "keywords": { "type": "array" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "slug", "class", "subject", "materialType", "status"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global institute settings and configuration.",
      "type": "object",
      "properties": {
        "instituteName": { "type": "string" },
        "logo": { "type": "string" },
        "contactDetails": { "type": "object" },
        "academicSession": { "type": "string" },
        "defaultFeeSettings": { "type": "object" },
        "receiptSettings": { "type": "object" },
        "whatsappConfig": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "StoreProduct": {
      "title": "StoreProduct",
      "description": "Sunshine Store books and educational resources product recommendation catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Book", "Resource"] },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "featuredImage": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "brandName": { "type": "string" },
        "publisher": { "type": "string" },
        "author": { "type": "string" },
        "whySunshineRecommends": { "type": "string" },
        "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED", "ARCHIVED"] }
      },
      "required": ["type", "title", "slug", "status"]
    },
    "StoreCategory": {
      "title": "StoreCategory",
      "description": "Categories for Sunshine Store products.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "productType": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "StoreBrand": {
      "title": "StoreBrand",
      "description": "Brands and Publishers for Sunshine Store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "type": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User authentication and profile data."
    },
    "students/{studentId}": {
      "schema": "Student",
      "description": "Student core profiles."
    },
    "teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teacher profiles and class assignments."
    },
    "classes/{classId}": {
      "schema": "Class",
      "description": "Configurable school classes (Class 1 to 10+)."
    },
    "admissions/{admissionId}": {
      "schema": "Admission",
      "description": "Separate student admission history documents."
    },
    "fees/{feeId}": {
      "schema": "Fee",
      "description": "Fee obligations per student and month."
    },
    "payments/{paymentId}": {
      "schema": "Payment",
      "description": "Individual payment transaction history."
    },
    "attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Daily student attendance records."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Multi-channel dispatch logs."
    },
    "audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit trail logs for administrative accountability."
    },
    "settings/{settingId}": {
      "schema": "Setting",
      "description": "Central institute settings and parameters."
    },
    "study_materials/{materialId}": {
      "schema": "StudyMaterial",
      "description": "Central repository for study materials, notes, assignments, PYQs, and educational resources."
    },
    "store_products/{productId}": {
      "schema": "StoreProduct",
      "description": "Products catalog for books and educational resources."
    },
    "store_categories/{categoryId}": {
      "schema": "StoreCategory",
      "description": "Categories for store items."
    },
    "store_brands/{brandId}": {
      "schema": "StoreBrand",
      "description": "Brands and Publishers directory."
    }
  }
}
