rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Production Normalized ERP Collections
    match /users/{userId} { allow read, write: if true; }
    match /students/{studentId} { allow read, write: if true; }
    match /teachers/{teacherId} { allow read, write: if true; }
    match /classes/{classId} { allow read, write: if true; }
    match /admissions/{admissionId} { allow read, write: if true; }
    match /fees/{feeId} { allow read, write: if true; }
    match /payments/{paymentId} { allow read, write: if true; }
    match /attendance/{attendanceId} { allow read, write: if true; }
    match /notifications/{notificationId} { allow read, write: if true; }
    // Historical & Log Collections (Immutable)
    match /audit_logs/{logId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /student_class_history/{historyId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /student_teacher_history/{historyId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /student_timelines/{timelineId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /domain_events/{eventId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    match /settings/{settingId} { allow read, write: if true; }

    // Fallback for document wildcards
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
